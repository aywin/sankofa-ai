# URL du projet Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co

# Service role key (Project Settings > API > service_role)
# Ne JAMAIS exposer cette clé au client. Utilisée uniquement dans les
# routes API / scripts serveur (lib/supabase.ts).
SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-role

# Anon / publishable key (Project Settings > API > anon public)
# Celle-ci EST prévue pour le navigateur — utilisée pour l'auth et l'accès
# à la table "conversations", protégée par les policies RLS (voir
# supabase/schema_users.sql). Jamais utilisée pour maladies/plantes/usages.
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-publique

# Clé API Gemini (Google AI Studio)
GOOGLE_GENERATIVE_AI_API_KEY=ta-cle-gemini
